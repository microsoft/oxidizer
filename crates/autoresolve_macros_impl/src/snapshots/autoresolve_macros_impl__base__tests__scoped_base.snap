struct ScopedRoots {
    request_context: RequestContext,
}
impl ::autoresolve::ResolveFrom<Base> for RequestContext {
    type Inputs = ::autoresolve::ResolutionDepsEnd;
    fn new(_: ::autoresolve::ResolutionDepsEnd) -> Self {
        unreachable!("scoped root types are inserted by ScopedBase::insert_into")
    }
}
impl ::autoresolve::ScopedBase<Base> for ScopedRoots {
    fn insert_into(self, __resolver: &mut ::autoresolve::ScopedResolver<Base>) {
        let Self { request_context } = self;
        __resolver.insert(request_context);
    }
}
