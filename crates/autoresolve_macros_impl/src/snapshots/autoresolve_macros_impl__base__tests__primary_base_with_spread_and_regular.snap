struct Base {
    builtins: Builtins,
    telemetry: Telemetry,
}
Builtins!(@ impls Base);
impl ::autoresolve::ResolveFrom<Base> for Telemetry {
    type Inputs = ::autoresolve::ResolutionDepsEnd;
    fn new(_: ::autoresolve::ResolutionDepsEnd) -> Self {
        unreachable!("base types are pre-inserted into the resolver")
    }
}
impl ::autoresolve::BaseType<Base> for Base {
    fn insert_into(self, __store: &mut impl ::autoresolve::ResolverStore<Base>) {
