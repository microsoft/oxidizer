source: crates/observed_macros/src/enrichment.rs
expression: output
---
const _: () = {
    impl ::observed::enrichment::Enrichment for RequestContext {
        fn into_entries(
            self,
        ) -> ::std::vec::Vec<::observed::__private::EnrichmentEntry> {
            let mut entries = ::std::vec::Vec::with_capacity(2usize);
            entries
                .push(
                    ::observed::__private::EnrichmentEntry::new("method", self.method),
                );
            entries
                .push(
                    ::observed::__private::EnrichmentEntry::unclassified(
                            "internal_flag",
                            self.internal_flag,
                        )
                        .exclude_from_logs(),
                );
            entries
        }
    }
};
