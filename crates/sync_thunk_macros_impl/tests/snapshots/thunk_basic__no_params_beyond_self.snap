    fn __simple_shim(ptr: *mut ()) {
        #[allow(non_camel_case_types, dead_code)]
        struct __simple_RawTask {
            self_ptr: *const (),
        }
        let state = unsafe {
            &*ptr.cast::<::sync_thunk::StackState<i32, __simple_RawTask>>()
