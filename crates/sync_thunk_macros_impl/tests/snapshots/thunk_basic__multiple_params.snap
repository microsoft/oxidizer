        match panic_result {
            Ok(result) => {
                unsafe { state.complete(result) };
            }
            Err(_) => {
                state.mark_panicked();
            }
        }
        state.wake();
    }
    async fn multi(&self, a: u32, b: &str, c: &mut Vec<u8>) -> bool {
        #[allow(non_camel_case_types, dead_code)]
        struct __multi_RawTask {
            self_ptr: *const (),
            a: u32,
            b: *const str,
            c: *mut Vec<u8>,
        }
        unsafe impl Send for __multi_RawTask {}
        let state = ::sync_thunk::StackState::<bool, __multi_RawTask>::new();
        let raw_task = __multi_RawTask {
            self_ptr: self as *const Self as *const (),
            a,
            b: b as *const str,
            c: c as *mut Vec<u8>,
        };
        unsafe {
            state.set_task(raw_task);
        }
        let work_item = ::sync_thunk::WorkItem::new(
            state.as_mut_ptr().cast::<()>(),
            Self::__multi_shim,
        );
        self.thunker.send(work_item);
        ::sync_thunk::ThunkFuture::new(&state).await
