    fn __multi_shim(ptr: *mut ()) {
        #[allow(non_camel_case_types, dead_code)]
        struct __multi_RawTask {
            self_ptr: *const (),
            a: u32,
            b: *const str,
            c: *mut Vec<u8>,
        }
        let state = unsafe {
            &*ptr.cast::<::sync_thunk::StackState<bool, __multi_RawTask>>()
        };
        let task = unsafe { state.take_task() }
            .expect("thunk task was set before dispatch");
        let self_ref = unsafe { &*task.self_ptr.cast::<Self>() };
        let a = task.a;
        let b = unsafe { &*task.b };
        let c = unsafe { &mut *task.c };
        let panic_result = ::std::panic::catch_unwind(
            ::std::panic::AssertUnwindSafe(|| { self_ref.__multi_inner(a, b, c) }),
