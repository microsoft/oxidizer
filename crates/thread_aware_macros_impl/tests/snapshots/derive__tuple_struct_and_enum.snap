impl ::thread_aware::ThreadAware for E {
    fn relocate(
        &mut self,
        source: Option<::thread_aware::affinity::Affinity>,
        destination: ::thread_aware::affinity::Affinity,
    ) {
        match self {
            Self::A(_v0) => {
                ::thread_aware::ThreadAware::relocate(_v0, source, destination);
            }
            Self::B(_v0, _v1) => {
                ::thread_aware::ThreadAware::relocate(_v0, source, destination);
            }
            Self::C { x, y } => {
                ::thread_aware::ThreadAware::relocate(x, source, destination);
                ::thread_aware::ThreadAware::relocate(y, source, destination);
            }
        }
    }
}
