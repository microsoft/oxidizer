impl ::thread_aware::ThreadAware for E {
    fn relocated(
        &mut self,
        source: ::thread_aware::affinity::MemoryAffinity,
        destination: ::thread_aware::affinity::PinnedAffinity,
    ) {
        match self {
            Self::A(_v0) => {
                ::thread_aware::ThreadAware::relocated(_v0, source, destination);
            }
            Self::B(_v0, _v1) => {
                ::thread_aware::ThreadAware::relocated(_v0, source, destination);
            }
            Self::C { x, y } => {
                ::thread_aware::ThreadAware::relocated(x, source, destination);
                ::thread_aware::ThreadAware::relocated(y, source, destination);
            }
        }
    }
}
