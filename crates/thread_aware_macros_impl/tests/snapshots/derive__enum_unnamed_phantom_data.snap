impl<T, U> ::thread_aware::ThreadAware for EnumUnnamedPhantom<T, U> {
    fn relocated(
        &mut self,
        source: ::thread_aware::affinity::MemoryAffinity,
        destination: ::thread_aware::affinity::PinnedAffinity,
    ) {
        match self {
            Self::Variant(_v0, _v1) => {
                ::thread_aware::ThreadAware::relocated(_v0, source, destination);
            }
            Self::Other(_v0, _v1) => {
                ::thread_aware::ThreadAware::relocated(_v0, source, destination);
            }
        }
    }
}
