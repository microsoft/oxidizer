impl<T: ::thread_aware::ThreadAware> ::thread_aware::ThreadAware for RefUse<T> {
    fn relocated(
        &mut self,
        source: ::thread_aware::affinity::MemoryAffinity,
        destination: ::thread_aware::affinity::PinnedAffinity,
    ) {
        ::thread_aware::ThreadAware::relocated(&mut self.0, source, destination);
    }
}
