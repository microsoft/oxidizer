impl<T, U> ::thread_aware::ThreadAware for EnumNamedPhantom<T, U> {
    fn relocate(
        &mut self,
        source: Option<::thread_aware::affinity::Affinity>,
        destination: ::thread_aware::affinity::Affinity,
    ) {
        match self {
            Self::Variant { data, marker } => {
                ::thread_aware::ThreadAware::relocate(data, source, destination);
            }
            Self::Other { value, phantom } => {
                ::thread_aware::ThreadAware::relocate(value, source, destination);
            }
        }
    }
}
